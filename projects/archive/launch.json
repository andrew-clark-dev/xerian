{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "web",
            "request": "launch",
            "type": "dart",
            "args": ["-dchrome"]
        },       
        {
            "name": "web-drop-cors",
            "request": "launch",
            "type": "dart",
            "args": ["-dchrome", "--web-browser-flag=--disable-web-security"]
        },
        {
            "name": "xerian (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "xerian (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
        
    ]
}